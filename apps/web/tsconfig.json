{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "types": ["vitest/globals", "@testing-library/jest-dom"],
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@eva/types": ["../../packages/types/index.ts"],
      "@eva/schemas": ["../../packages/schemas/index.ts"],
      "@eva/schemas/screening": ["../../packages/schemas/screening.ts"],
      "@eva/schemas/nutrition-exchanges": ["../../packages/schemas/nutrition-exchanges.ts"],
      "@eva/schemas/bodycomp": ["../../packages/schemas/bodycomp.ts"],
      "@eva/calc": ["../../packages/calc/index.ts"],
      "@eva/brand-kit": ["../../packages/brand-kit/index.ts"],
      "@eva/tiers": ["../../packages/tiers/index.ts"],
      "@eva/module-catalog": ["../../packages/module-catalog/catalog.ts"],
      "@eva/feature-prefs": ["../../packages/feature-prefs/index.ts"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules", ".next/dev"]
}
