{
  "cli": {
    "version": ">= 14.0.0",
    "appVersionSource": "remote",
    "promptToConfigurePushNotifications": false
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      }
    },
    "prodpreview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "buildConfiguration": "Release",
        "credentialsSource": "local",
        "distribution": "store"
      },
      "env": {
        "APP_ENV": "production",
        "EXPO_ROUTER_APP_ROOT": "apps/mobile/app"
      }
    },
    "staging": {
      "distribution": "internal",
      "ios": {
        "buildConfiguration": "Release",
        "distribution": "store",
        "credentialsSource": "local"
      },
      "env": {
        "APP_ENV": "staging",
        "EXPO_ROUTER_APP_ROOT": "apps/mobile/app",
        "EXPO_PUBLIC_SUPABASE_URL": "http://10.93.54.116:54321",
        "EXPO_PUBLIC_SUPABASE_ANON_KEY": "sb_publishable_ACJWlzQHlZjBrEguHvfOxg_3BJgxAaH"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "APP_ENV": "production",
        "EXPO_ROUTER_APP_ROOT": "apps/mobile/app"
      },
      "android": {
        "credentialsSource": "remote"
      },
      "ios": {
        "credentialsSource": "local"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "jvillegas.dev@gmail.com",
        "ascAppId": "6770426633",
        "appleTeamId": "5GKWMMZ46Q"
      },
      "android": {
        "serviceAccountKeyPath": "./google-service-account.json",
        "track": "internal"
      }
    },
    "prodpreview": {
      "ios": {
        "appleId": "jvillegas.dev@gmail.com",
        "ascAppId": "6770426633",
        "appleTeamId": "5GKWMMZ46Q"
      }
    }
  }
}
