{
  "cli": {
    "version": ">= 14.0.0",
    "appVersionSource": "remote",
    "promptToConfigurePushNotifications": false
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      }
    },
    "staging": {
      "distribution": "internal",
      "ios": {
        "buildConfiguration": "Release"
      },
      "env": {
        "APP_ENV": "staging"
      }
    },
    "production": {
      "autoIncrement": true,
      "credentialsSource": "local",
      "env": {
        "APP_ENV": "production",
        "EXPO_ROUTER_APP_ROOT": "apps/mobile/app"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "jvillegas.dev@gmail.com",
        "ascAppId": "PLACEHOLDER_ASC_APP_ID",
        "appleTeamId": "5GKWMMZ46Q"
      },
      "android": {
        "serviceAccountKeyPath": "./google-service-account.json",
        "track": "internal"
      }
    }
  }
}
