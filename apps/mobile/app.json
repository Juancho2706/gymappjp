{
  "expo": {
    "name": "EVA",
    "slug": "eva",
    "scheme": "eva",
    "version": "1.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/eva-mark-filled.png",
      "resizeMode": "contain",
      "backgroundColor": "#07080C"
    },
    "ios": {
      "icon": "./assets/icon-ios.png",
      "bundleIdentifier": "cl.evaapp.eva",
      "buildNumber": "3",
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "EVA usa la cámara para fotos de progreso y escanear códigos de barras de alimentos.",
        "NSPhotoLibraryUsageDescription": "Para seleccionar tu foto de perfil",
        "NSMotionUsageDescription": "Para contar tus pasos durante el entrenamiento",
        "NSFaceIDUsageDescription": "Usá Face ID para entrar a EVA de forma segura.",
        "NSBluetoothAlwaysUsageDescription": "EVA usa Bluetooth para conectar tu sensor de frecuencia cardiaca (cinta o reloj) durante el cardio.",
        "NSHealthShareUsageDescription": "EVA lee tus pasos y sueño desde Salud para autocompletar tus hábitos del día.",
        "NSHealthUpdateUsageDescription": "EVA no escribe datos en Salud; solo lee pasos y sueño con tu permiso.",
        "ITSAppUsesNonExemptEncryption": false,
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    "android": {
      "package": "cl.evaapp.eva",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.RECORD_AUDIO",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.BLUETOOTH_SCAN",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.health.READ_STEPS",
        "android.permission.health.READ_SLEEP"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "eva-app.cl",
              "pathPrefix": "/c/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        },
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "eva-app.cl",
              "pathPrefix": "/invite/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        },
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "eva-app.cl",
              "path": "/reset-password"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26
          }
        }
      ],
      "expo-router",
      "expo-updates",
      [
        "expo-camera",
        {
          "cameraPermission": "EVA usa la cámara para fotos de progreso y escanear códigos de barras de alimentos."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "EVA necesita acceso a tu galería para el check-in semanal."
        }
      ],
      "./plugins/with-android-cleartext",
      "./plugins/with-gradle-jvmargs",
      "./plugins/with-privacy-manifest",
      [
        "react-native-ble-plx",
        {
          "isBackgroundEnabled": false,
          "neverForLocation": true,
          "modes": ["central"],
          "bluetoothAlwaysPermission": "EVA usa Bluetooth para conectar tu sensor de frecuencia cardiaca (cinta o reloj) durante el cardio."
        }
      ],
      [
        "react-native-health",
        {
          "isClinicalDataEnabled": false,
          "healthSharePermission": "EVA lee tus pasos y sueño desde Salud para autocompletar tus hábitos del día.",
          "healthUpdatePermission": "EVA no escribe datos en Salud; solo lee pasos y sueño con tu permiso."
        }
      ],
      "react-native-health-connect",
      "react-native-notify-kit",
      "expo-secure-store",
      "./plugins/with-ios-modular-headers",
      [
        "@sentry/react-native/expo",
        {
          "organization": "eva-zs",
          "project": "eva-mobile"
        }
      ]
    ],
    "updates": {
      "url": "https://u.expo.dev/a5f4f7c0-861c-48b1-9ed6-fc46e7843844",
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "eas": {
        "projectId": "a5f4f7c0-861c-48b1-9ed6-fc46e7843844"
      }
    },
    "owner": "juandeveva"
  }
}
