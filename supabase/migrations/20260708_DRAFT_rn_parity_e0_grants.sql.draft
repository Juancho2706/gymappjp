-- ----------------------------------------------------------------------------
-- (a) coaches — GRANT SELECT a `anon` de columnas de branding del login alumno.
--     ESTADO: COMPLETO. Las 20 columnas que lee proxy.ts (coachBrandingPromise,
--     corre como anon en el login pre-auth) tienen GRANT SELECT(col) a anon.
--     Aplicado por las migraciones:
--       20260617033845_coaches_restrict_anon_select_to_branding.sql
--       20260621213600_grant_anon_select_whitelabel_v2_branding_cols.sql
--       20260702210000_whitelabel_presets_login_loader_columns.sql
--     Patron column-grant (gotcha CLAUDE.md: el REVOKE de columna es no-op; se
--     revoca a nivel TABLA y se re-grantea la lista completa). Re-asercion segura:
--
-- GRANT SELECT (
--   id, slug, full_name, brand_name, primary_color, logo_url, subscription_tier,
--   use_brand_colors_coach, welcome_message, loader_text, use_custom_loader,
--   loader_text_color, loader_icon_mode, brand_secondary_color, accent_light,
--   accent_dark, neutral_tint, logo_url_dark, brand_font_key, loader_variant,
--   theme_preset_key, login_layout_key, loader_config
-- ) ON public.coaches TO anon;
--   Reversa: REVOKE SELECT (<col>, ...) ON public.coaches FROM anon;  (o el REVOKE
--   total + re-grant de la lista minima, patron de 20260617033845).


-- ----------------------------------------------------------------------------
-- (b.1) clients — GRANT UPDATE(col) a `authenticated` de biometria/perfil.
--     ESTADO: COMPLETO. UPDATE a nivel TABLA revocado; 17 columnas re-grantadas
--     por 20260612140001_clients_scoping_grants.sql (verificado vivo). Incluye la
--     biometria que mobile escribe: birth_date, goal_weight_kg, resting_hr,
--     max_hr_override, ref_5k_time_sec. RLS clients_self_update (id = auth.uid())
--     deja al alumno escribir SU fila. Patron column-grant ya aplicado:
--
-- REVOKE UPDATE ON public.clients FROM authenticated, anon;
-- GRANT UPDATE (
--   age_confirmed_at, birth_date, created_at, email, force_password_change,
--   full_name, goal_weight_kg, is_active, is_archived, max_hr_override,
--   onboarding_completed, phone, ref_5k_time_sec, resting_hr,
--   subscription_start_date, updated_at, use_coach_brand_colors
-- ) ON public.clients TO authenticated;
--   (id/org_id/team_id/coach_id quedan solo service-role: scoping no user-editable.)
--   Reversa: GRANT UPDATE ON public.clients TO authenticated;  (vuelve a tabla-full)

-- (b.2) client_intake.sex — GRANT SELECT/INSERT/UPDATE(sex) a `authenticated`.
--     ESTADO: COMPLETO. Aplicado por 20260701120000_add_client_intake_sex.sql.
--     RLS client_intake_client (client_id = auth.uid(), FOR ALL) deja al alumno
--     escribir su propio sexo biologico (BMR/TDEE). Re-asercion segura:
--
-- GRANT SELECT (sex), INSERT (sex), UPDATE (sex) ON public.client_intake TO authenticated;
--   Reversa: REVOKE INSERT (sex), UPDATE (sex) ON public.client_intake FROM authenticated;

-- (b.3) workout_logs — columnas de sustitucion de maquina.
--     ESTADO: COMPLETO / NO REQUIERE GRANT DE COLUMNA. workout_logs tiene GRANT de
--     TABLA (SELECT/INSERT/UPDATE/DELETE) para authenticated, asi que las columnas
--     substituted_exercise_id / substituted_exercise_name / substitution_reason
--     (migracion 20260704160352_workout_logs_substitution_columns.sql) son
--     escribibles sin grant extra. RLS client_manage_logs (client_id = auth.uid())
--     deja al alumno escribir sus propios logs. Nada que agregar.


