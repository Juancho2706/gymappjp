NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public base URL used for canonical links and metadata.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: set automatically by Vercel in hosted environments.
VERCEL_URL=

# Optional: recipe search integration.
EDAMAM_APP_ID=
EDAMAM_APP_KEY=

# Payments (Sprint 2)
PAYMENT_PROVIDER=mercadopago
MERCADOPAGO_ACCESS_TOKEN=
NEXT_PUBLIC_MP_PUBLIC_KEY=
# Sandbox-only helper. Use a MercadoPago test user email (@testuser.com)
MERCADOPAGO_TEST_PAYER_EMAIL=
# Optional shared token appended to webhook URL for request validation.
MERCADOPAGO_WEBHOOK_TOKEN=

# Future provider support
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional: Playwright override for local/e2e environment.
PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000
