NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public base URL used for canonical links and metadata.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: set automatically by Vercel in hosted environments.
VERCEL_URL=

# Optional: recipe search integration.
EDAMAM_APP_ID=
EDAMAM_APP_KEY=

# Payments (Sprint 2)
PAYMENT_PROVIDER=mercadopago
MERCADOPAGO_ACCESS_TOKEN=
NEXT_PUBLIC_MP_PUBLIC_KEY=
# Sandbox-only helper. Use a MercadoPago test user email (@testuser.com)
MERCADOPAGO_TEST_PAYER_EMAIL=
# Optional shared token appended to webhook URL for request validation.
MERCADOPAGO_WEBHOOK_TOKEN=

# Future provider support
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional: Playwright override for local/e2e environment.
PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000

# Rate limiting (SEC-002 / SEC-003) — recomendado en producción (Upstash Redis REST).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Landing: YouTube video id (11 chars) o URL (watch/embed/youtu.be) para la demo embebida (GRO-003).
NEXT_PUBLIC_DEMO_VIDEO_URL=

# Playwright CI / QA-014–015 (usuario alumno con programa y plan asignados).
E2E_COACH_SLUG=
E2E_CLIENT_EMAIL=
E2E_CLIENT_PASSWORD=
E2E_WORKOUT_PLAN_ID=

# Vitest RLS integration (QA-021–027). Ver README.
SUPABASE_RLS_INTEGRATION=
RLS_TEST_CLIENT_A_EMAIL=
RLS_TEST_CLIENT_A_PASSWORD=
RLS_TEST_PEER_CLIENT_ID=
RLS_TEST_OTHER_COACH_CLIENT_ID=

# Sprint 5 retention/ops
# Resend API for RET-002 drip emails
RESEND_API_KEY=
EMAIL_FROM="EVA <beta@gymappjp.com>"
# Internal auth token for drip runner endpoint
DRIP_CRON_TOKEN=
# Internal auth token for beta health monitor endpoint
BETA_MONITOR_TOKEN=
