NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public base URL used for canonical links and metadata.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: set automatically by Vercel in hosted environments.
VERCEL_URL=

# Optional: recipe search integration.
EDAMAM_APP_ID=
EDAMAM_APP_KEY=

# Optional: Playwright override for local/e2e environment.
PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000
