# Copy to .env.local and fill in real values. Never commit .env.local.

# --- Performance (optional) ---
# PERF_NAV_SERVER=1   # logs [perf:server] en consola (getDirectoryPulse, getCoachDashboardData)
# PERF_COACH_EMAIL=   # para smoke e2e autenticado de navegación
# PERF_COACH_PASSWORD=

# --- Supabase (required) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Management API (optional — e.g. npm run supabase:disable-signup)
# SUPABASE_ACCESS_TOKEN=

# --- Site / URLs (recommended) ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# NEXT_PUBLIC_APP_URL=
# VERCEL_URL is set automatically on Vercel

# --- Payments (Mercado Pago default) ---
PAYMENT_PROVIDER=mercadopago
# MERCADOPAGO_ACCESS_TOKEN=
# MERCADOPAGO_WEBHOOK_TOKEN=        # required in production (NODE_ENV=production)
# MERCADOPAGO_WEBHOOK_SIGNING_SECRET= # optional: verify x-signature HMAC (MP dashboard secret)
# MERCADOPAGO_TEST_PAYER_EMAIL=

# Stripe (optional / future)
# STRIPE_SECRET_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_WEBHOOK_SECRET=

# --- Rate limiting (recommended in production) ---
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# --- Recipes (optional) ---
# EDAMAM_APP_ID=
# EDAMAM_APP_KEY=

# --- Landing / marketing ---
# NEXT_PUBLIC_DEMO_VIDEO_URL=

# --- Email (optional) ---
# RESEND_API_KEY=
# EMAIL_FROM=

# --- Internal / ops (optional) ---
# DRIP_CRON_TOKEN=
# BETA_MONITOR_TOKEN=
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# CRON_SECRET=   # protege GET /api/cron/nutrition-cycles (Vercel Cron lo pasa como Bearer token)

# --- Web Push / VAPID ---
# VAPID_EMAIL=mailto:contacto@eva-app.cl
# VAPID_PUBLIC_KEY=   # generate: npx web-push generate-vapid-keys
# VAPID_PRIVATE_KEY=  # generate: npx web-push generate-vapid-keys
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=  # same as VAPID_PUBLIC_KEY but exposed to client

# --- Beta invite (required for /registro-beta) ---
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# BETA_INVITE_TOKEN=

# --- Admin / CEO Panel ---
# Comma-separated list of emails allowed to access /admin/*
# ADMIN_EMAILS=contacto@eva-app.cl

# --- Playwright ---
# PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000
# E2E_COACH_SLUG=
# E2E_CLIENT_EMAIL=
# E2E_CLIENT_PASSWORD=
# E2E_WORKOUT_PLAN_ID=

# --- RLS integration tests (optional) ---
# SUPABASE_RLS_INTEGRATION=1
# RLS_TEST_CLIENT_A_EMAIL=
# RLS_TEST_CLIENT_A_PASSWORD=
# RLS_TEST_PEER_CLIENT_ID=
# RLS_TEST_OTHER_COACH_CLIENT_ID=
